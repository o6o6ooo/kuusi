rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isUploader(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /photos/{userId}/{fileName} {
      allow read: if signedIn();
      allow create: if isUploader(userId);
      allow update: if isUploader(userId);
      allow delete: if isUploader(userId);
    }
  }
}
